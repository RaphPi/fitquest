# Copie ce fichier en .env.screenshots et adapte les valeurs.
# Chemin du binaire Chromium/Chrome utilisé par Puppeteer (LXC Debian : /usr/bin/chromium)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Identifiants du compte utilisé pour générer les captures
SCREENSHOTS_EMAIL=user@example.com
SCREENSHOTS_PASSWORD=password

# URL de base de l'app front (Vite dev par défaut)
SCREENSHOTS_BASE_URL=http://localhost:5173
