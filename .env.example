# ─────────────────────────────────────────────
# FitQuest — Variables d'environnement
# Copier en `.env` et adapter (install.sh le génère automatiquement)
# ─────────────────────────────────────────────

# App
APP_PORT=80              # Port public du reverse proxy nginx (prod)
PORT=3001                # Port interne du backend Express
NODE_ENV=production      # production | development
UPLOAD_DIR=uploads       # Répertoire de stockage des photos de progression

# Base de données
POSTGRES_USER=fitquest
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=fitquest
DATABASE_URL=postgresql://fitquest:change_this_password@db:5432/fitquest
# ↑ "db" = nom du service Docker Compose ; à ajuster si Postgres est externe

# Auth
JWT_SECRET=change_this_secret_key  # Générer avec : openssl rand -hex 32 (install.sh le fait auto)
JWT_EXPIRES_IN=7d                  # Format : 1h | 7d | 30d
COOKIE_SECURE=false                # true uniquement si HTTPS est activé (reverse proxy TLS)

# IA (optionnel) — none | claude | ollama | lmstudio
AI_PROVIDER=none
CLAUDE_API_KEY=             # Clé API Anthropic — console.anthropic.com (requis si AI_PROVIDER=claude)
OLLAMA_URL=http://192.168.x.x:11434   # URL de l'instance Ollama sur le réseau local
LMSTUDIO_URL=http://192.168.x.x:1234  # URL de l'instance LM Studio sur le réseau local

# Notifications (optionnel)
FREESMS_TOKEN=         # Token FreeSMS (freesms.net) pour notifications SMS
HOME_ASSISTANT_URL=    # URL de l'instance Home Assistant (ex. http://192.168.x.x:8123)
HOME_ASSISTANT_TOKEN=  # Long-lived access token Home Assistant (Profil → Sécurité)
WEBHOOK_URL=           # Webhook générique (Discord, Slack, n8n, Make…)

# Puppeteer (export PDF — Phase 2). Évite le téléchargement de Chromium au build.
PUPPETEER_SKIP_DOWNLOAD=true
